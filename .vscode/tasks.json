{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build StationpediaAscended (Dev)",
            "type": "shell",
            "command": "dotnet build -c Debug -o build_dev; Copy-Item -Path 'build_dev\\StationpediaAscended.dll','descriptions.json' -Destination 'C:\\Program Files (x86)\\Steam\\steamapps\\common\\Stationeers\\BepInEx\\scripts\\' -Force; Copy-Item -Path '..\\About' -Destination 'C:\\Program Files (x86)\\Steam\\steamapps\\common\\Stationeers\\BepInEx\\scripts\\' -Recurse -Force",
            "options": {
                "cwd": "${workspaceFolder}/StationpediaAscended/mod"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Package StationpediaAscended (Release)",
            "type": "shell",
            "command": "dotnet build -c Release -o build_release; dotnet msbuild -t:Package",
            "options": {
                "cwd": "${workspaceFolder}/StationpediaAscended/mod"
            },
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Publish to Steam Workshop",
            "type": "shell",
            "command": "C:\\steamcmd\\steamcmd.exe +login spider7002 +workshop_build_item '${workspaceFolder}\\StationpediaAscended\\workshop_update.vdf' +quit",
            "options": {
                "cwd": "${workspaceFolder}/StationpediaAscended"
            },
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "Release & Publish StationpediaAscended",
            "dependsOn": ["Package StationpediaAscended (Release)", "Publish to Steam Workshop"],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build AimeeBugFixes (Dev)",
            "type": "shell",
            "command": "dotnet build -c Debug -o build_dev; $scriptsDir = 'C:\\Program Files (x86)\\Steam\\steamapps\\common\\Stationeers\\BepInEx\\scripts\\AimeeBugFixes'; New-Item -ItemType Directory -Force -Path $scriptsDir | Out-Null; Copy-Item -Path 'build_dev\\AimeeBugFixes.dll' -Destination $scriptsDir -Force; Copy-Item -Path 'About' -Destination $scriptsDir -Recurse -Force; Write-Host 'Deployed to' $scriptsDir",
            "options": {
                "cwd": "${workspaceFolder}/AimeeBugFixes"
            },
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Package AimeeBugFixes (Release)",
            "type": "shell",
            "command": "dotnet build -c Release -o build_release; $modsDir = 'C:\\Users\\marka\\Documents\\My Games\\Stationeers\\mods\\AimeeBugFixes'; New-Item -ItemType Directory -Force -Path $modsDir | Out-Null; Copy-Item -Path 'build_release\\AimeeBugFixes.dll' -Destination $modsDir -Force; Copy-Item -Path 'About' -Destination $modsDir -Recurse -Force; Write-Host 'Packaged to' $modsDir",
            "options": {
                "cwd": "${workspaceFolder}/AimeeBugFixes"
            },
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Publish AimeeBugFixes to Steam Workshop",
            "type": "shell",
            "command": "C:\\steamcmd\\steamcmd.exe +login spider7002 +workshop_build_item '${workspaceFolder}\\AimeeBugFixes\\workshop_update.vdf' +quit",
            "options": {
                "cwd": "${workspaceFolder}/AimeeBugFixes"
            },
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "Release & Publish AimeeBugFixes",
            "dependsOn": ["Package AimeeBugFixes (Release)", "Publish AimeeBugFixes to Steam Workshop"],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": []
        }
    ]
}
