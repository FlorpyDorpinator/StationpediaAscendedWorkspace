{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stationeers Device Logic Documentation",
  "description": "Schema for documenting logic types available on Stationeers devices",
  "type": "object",
  "required": ["prefabName", "prefabHash", "className", "inheritanceChain", "logicTypes"],
  "properties": {
    "prefabName": {
      "type": "string",
      "description": "The in-game display name of the device"
    },
    "prefabHash": {
      "type": "integer",
      "description": "Unique hash identifier used in IC10/MIPS code"
    },
    "className": {
      "type": "string",
      "description": "The C# class name implementing this device"
    },
    "inheritanceChain": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Class inheritance from most specific to base (e.g., ['AdvancedFurnace', 'FurnaceBase', 'Device'])"
    },
    "category": {
      "type": "string",
      "enum": ["Atmospheric", "Power", "Logic", "Production", "Storage", "Sensors", "Structures", "Vehicles", "Wearables", "Rockets", "Misc"],
      "description": "Device category for organization"
    },
    "logicTypes": {
      "type": "array",
      "items": { "$ref": "#/definitions/logicTypeEntry" },
      "description": "All logic types available on this device"
    },
    "slotLogic": {
      "type": "array",
      "items": { "$ref": "#/definitions/slotLogicEntry" },
      "description": "Slot-based logic (for devices with item slots)"
    },
    "modes": {
      "type": "array",
      "items": { "$ref": "#/definitions/modeEntry" },
      "description": "Available mode values if device has Mode logic"
    },
    "notes": {
      "type": "string",
      "description": "General notes about this device's logic behavior"
    },
    "sourceFile": {
      "type": "string",
      "description": "Path to the source file where logic is implemented"
    },
    "gameVersion": {
      "type": "string",
      "description": "Game version this documentation was extracted from"
    }
  },
  "definitions": {
    "logicTypeEntry": {
      "type": "object",
      "required": ["name", "enumValue", "canRead", "canWrite"],
      "properties": {
        "name": {
          "type": "string",
          "description": "LogicType enum name (e.g., 'Temperature', 'Pressure')"
        },
        "enumValue": {
          "type": "integer",
          "description": "Numeric value of the LogicType enum"
        },
        "canRead": {
          "type": "boolean",
          "description": "Whether this value can be read via 'l' instruction"
        },
        "canWrite": {
          "type": "boolean",
          "description": "Whether this value can be written via 's' instruction"
        },
        "readBehavior": {
          "type": "object",
          "properties": {
            "description": {
              "type": "string",
              "description": "Human-readable explanation of what reading this value returns"
            },
            "unit": {
              "type": "string",
              "description": "Unit of measurement (e.g., 'Kelvin', 'kPa', 'Watts', 'ratio 0-1')"
            },
            "range": {
              "type": "object",
              "properties": {
                "min": { "type": "number" },
                "max": { "type": "number" }
              }
            },
            "conditions": {
              "type": "string",
              "description": "Any conditions that affect the read value (e.g., 'Returns -1 if unpowered')"
            },
            "sourceProperty": {
              "type": "string",
              "description": "The actual C# property/method that provides this value"
            }
          }
        },
        "writeBehavior": {
          "type": "object",
          "properties": {
            "description": {
              "type": "string",
              "description": "Human-readable explanation of what writing this value does"
            },
            "validValues": {
              "type": "object",
              "properties": {
                "min": { "type": "number" },
                "max": { "type": "number" },
                "enumValues": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "value": { "type": "number" },
                      "meaning": { "type": "string" }
                    }
                  }
                }
              }
            },
            "sideEffects": {
              "type": "string",
              "description": "What actually happens when you write this value"
            },
            "autoOverwritten": {
              "type": "boolean",
              "description": "Whether the game automatically overwrites this value (like Mode on furnaces)"
            },
            "requiresPower": {
              "type": "boolean",
              "description": "Whether writing requires the device to be powered"
            }
          }
        },
        "inheritedFrom": {
          "type": "string",
          "description": "Which class in the inheritance chain provides this logic (null if native)"
        }
      }
    },
    "slotLogicEntry": {
      "type": "object",
      "required": ["slotIndex", "slotName", "logicSlotTypes"],
      "properties": {
        "slotIndex": {
          "type": "integer",
          "description": "Numeric index of the slot"
        },
        "slotName": {
          "type": "string",
          "description": "Human-readable slot name (e.g., 'Import', 'Export', 'Battery')"
        },
        "logicSlotTypes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "canRead": { "type": "boolean" },
              "canWrite": { "type": "boolean" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "modeEntry": {
      "type": "object",
      "required": ["value", "name"],
      "properties": {
        "value": {
          "type": "integer",
          "description": "Numeric mode value"
        },
        "name": {
          "type": "string",
          "description": "Mode name from ModeStrings array"
        },
        "description": {
          "type": "string",
          "description": "What this mode does"
        }
      }
    }
  }
}
